rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
    }
    function isPatron()    { return role() == 'patron' }
    function isChef()      { return role() == 'chef_equipe' }
    function isOuvrier()   { return role() == 'ouvrier' }
    function isComptable() { return role() == 'comptable' }
    function isAuth()      { return request.auth != null }

    // USERS
    // C2 FIX — un ouvrier ne peut plus modifier son rôle ni son statut actif
    match /users/{uid} {
      allow read:   if request.auth.uid == uid || isPatron()
      allow create: if request.auth.uid == uid || isPatron()
      allow update: if isPatron()
        || (request.auth.uid == uid
            && !request.resource.data.diff(resource.data)
                .affectedKeys().hasAny(['role', 'actif']))
      allow delete: if false
    }

    // INVITATIONS
    // C3 FIX — lecture publique (nécessaire pour /rejoindre avant connexion)
    //          mise à jour restreinte : seul le patron peut tout changer,
    //          un user connecté peut uniquement marquer "accepte" (son inscription)
    match /invitations/{token} {
      allow get:    if true          // lecture d'un token spécifique (page /rejoindre, pré-auth)
      allow list:   if isPatron()    // M2 FIX — listing collection réservé au patron
      allow create: if isPatron()
      allow update: if isPatron()
        || (isAuth()
            && request.resource.data.statut == 'accepte'
            && resource.data.statut != 'accepte'
            && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['statut', 'accepteAt', 'uid']))
      allow delete: if isPatron()
    }

    // CLIENTS
    match /clients/{id} {
      allow read, write: if isPatron() || isComptable()
      allow delete:      if false
    }

    // FACTURES — suppression absolument interdite
    match /factures/{id} {
      allow read:   if isPatron() || isComptable()
      allow create: if isPatron()
      allow update: if isPatron()
      allow delete: if false
    }

    // DEVIS
    match /devis/{id} {
      allow read, write: if isPatron()
      allow delete:      if isPatron()
    }

    // CHANTIERS
    match /chantiers/{id} {
      allow read:   if isAuth()
      allow write:  if isPatron() || isChef()
      allow delete: if isPatron()
    }

    // POINTAGES
    // I3 FIX — l'ouvrier ne peut modifier que les champs de fin de journée
    //          bloqué : heureDebut, chantierId, ouvrierId, validePar, chantierAdresse
    match /pointages/{id} {
      allow create: if isAuth()
      allow read:   if request.auth.uid == resource.data.ouvrierId
                    || isPatron() || isChef()
      allow update: if isPatron() || isChef()
        || (request.auth.uid == resource.data.ouvrierId
            && resource.data.statut == 'en_cours'
            && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly([
                  'heureFin', 'statut', 'coordsFin', 'heuresTravaillees',
                  'pause', 'tracesGPS', 'heuresNormales',
                  'heuresSupp25', 'heuresSupp50', 'heuresSupp', 'updatedAt'
                ])
            && request.resource.data.statut in ['en_cours', 'a_verifier'])
      allow delete: if false
    }

    // FICHES MENSUELLES
    match /fiches_mensuelles/{id} {
      allow read, write, delete: if isPatron()
    }

    // STOCK
    match /stock/{id} {
      allow read:  if isPatron() || isChef()
      allow write: if isPatron()
    }

    // TICKETS
    match /tickets/{id} {
      allow create: if isAuth()
      allow read:   if request.auth.uid == resource.data.ouvrierId
                    || isPatron() || isChef()
      allow update: if isPatron()
      allow delete: if false
    }

    // DEMANDES MATÉRIEL
    match /demandes_materiel/{id} {
      allow read:   if isAuth()
      allow create: if isAuth()
      allow update: if isPatron() || isChef()
      allow delete: if isPatron()
    }

    // ÉQUIPES
    match /equipes/{id} {
      allow read:   if isPatron() || isChef()
      allow create: if isPatron()
      allow update: if isPatron()
      allow delete: if isPatron()
    }

    // PHOTOS CHANTIER
    match /photos_chantier/{id} {
      allow read:   if isAuth()
      allow create: if isAuth()
      allow delete: if isPatron() || request.auth.uid == resource.data.auteurId
      allow update: if false
    }

    // PLANNING
    match /planning/{id} {
      allow read:   if isAuth()
      allow create: if isPatron() || isChef()
      allow update: if isPatron() || isChef()
      allow delete: if isPatron() || isChef()
    }

    // TRÉSORERIE
    match /tresorerie/{id} {
      allow read:  if isPatron() || isComptable()
      allow write: if isPatron()
    }
    match /tresorerie_solde/{id} {
      allow read:  if isPatron() || isComptable()
      allow write: if isPatron()
    }

    // PARAMÈTRES
    match /parametres/{id} {
      allow read:  if isAuth()
      allow write: if isPatron()
    }

    // BONS DE COMMANDE
    match /bons_commande/{id} {
      allow read:   if isPatron()
      allow create: if isPatron()
      allow update: if isPatron()
      allow delete: if false
    }
  }
}
