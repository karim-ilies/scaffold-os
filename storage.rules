rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isPatron() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'patron'
    }
    function isComptable() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'comptable'
    }
    function isChef() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'chef_equipe'
    }

    // Photos chantier — lecture tous authentifiés, écriture image < 10MB
    match /photos_chantier/{chantierId}/{file} {
      allow read:  if request.auth != null
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
      allow delete: if request.auth != null
    }

    // Documents ouvriers — ouvrier voit les siens, patron voit tout
    match /documents/{uid}/{file} {
      allow read, write: if request.auth.uid == uid || isPatron()
    }

    // Archives pointages — patron uniquement
    match /archives/{uid}/{file} {
      allow read, write: if isPatron()
    }

    // I2 FIX — PDFs factures : patron et comptable uniquement, PDF uniquement
    match /factures/{factureId}/{file} {
      allow read:  if request.auth != null && (isPatron() || isComptable())
      allow write: if request.auth != null
                   && (isPatron() || isComptable())
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('application/pdf')
    }

    // Logo et paramètres société — patron uniquement
    match /parametres/{file} {
      allow read:  if request.auth != null
      allow write: if isPatron()
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
    }

    // Tickets de caisse — propriétaire ou patron/chef
    match /tickets/{uid}/{file} {
      allow read:  if request.auth.uid == uid || isPatron() || isChef()
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
    }

    // Bons de commande PDF — patron uniquement
    match /bdc/{file} {
      allow read:  if isPatron()
      allow write: if isPatron()
                   && request.resource.size < 10 * 1024 * 1024
    }
  }
}
